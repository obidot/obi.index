# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://obidot:obidot@localhost:5432/obidot_index"

# ── Chain ─────────────────────────────────────────────────
CHAIN_ID=420420417
RPC_URL="https://eth-rpc-testnet.polkadot.io/"
BLOCKSCOUT_URL="https://blockscout-testnet.polkadot.io"

# ── Server ────────────────────────────────────────────────
PORT=4350

# ── Sync ──────────────────────────────────────────────────
POLL_INTERVAL_MS=60000
# Optional: block number to start syncing from (0 = genesis)
START_BLOCK=0

# ── AI Agent ──────────────────────────────────────────────
# LLM provider: "openrouter" | "openai" | "anthropic"
LLM_PROVIDER="openrouter"
LLM_API_KEY=""
LLM_MODEL="anthropic/claude-sonnet-4"

# Agent private key (for signing & submitting EIP-712 intents)
# Must hold SOLVER_ROLE (executeIntent) + STRATEGIST_ROLE (executeLocalSwap).
AGENT_PRIVATE_KEY=""

# Agent slippage (basis points). Max 200 (2%) — vault enforces ceiling on-chain.
AGENT_MAX_SLIPPAGE_BPS=200

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL="info"
